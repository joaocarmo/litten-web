{
  "name": "litten-web",
  "title": "Litten",
  "version": "1.0.0",
  "description": "Find a pet to grow your family. Post your missing pet, including photos, location, and other information. Post about a missing pet that you've found.",
  "homepage": "https://litten.app",
  "private": true,
  "main": "src/pages/index.js",
  "repository": "git@github.com:joaocarmo/litten-web.git",
  "author": {
    "name": "João Carmo",
    "email": "17721880+joaocarmo@users.noreply.github.com",
    "url": "https://joaocarmo.com/"
  },
  "contributors": [],
  "license": "MIT",
  "browserslist": {
    "production": [
      "> 0.25%",
      "not dead"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version"
    ]
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "gatsby build",
    "clean": "gatsby clean",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "stylelint:fix": "stylelint ./src/**/*.scss --fix",
    "stylelint": "stylelint ./src/**/*.scss",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "pretty:fix": "prettier --write .",
    "pretty": "prettier --check .",
    "push": "git add . && gitmoji -c && git push",
    "serve": "gatsby serve",
    "start": "gatsby develop --port 8001",
    "test": "echo \"Error: no test specified\" && exit 0",
    "type-check": "tsc --noEmit"
  },
  "lint-staged": {
    "*.js": "eslint --cache --fix",
    "*.css": "stylelint --fix",
    "*.{js,json,css,md}": "prettier --write"
  },
  "dependencies": {
    "@reach/router": "^1.3.4",
    "bowser": "^2.14.1",
    "classnames": "^2.5.1",
    "dompurify": "^3.3.3",
    "gatsby": "^5.16.1",
    "gatsby-background-image": "^1.6.0",
    "gatsby-cli": "^5.16.0",
    "gatsby-plugin-i18n": "^1.0.1",
    "gatsby-plugin-image": "^3.16.0",
    "gatsby-plugin-manifest": "^5.16.0",
    "gatsby-plugin-nprogress": "^5.16.0",
    "gatsby-plugin-react-helmet": "^6.16.0",
    "gatsby-plugin-sass": "^6.16.0",
    "gatsby-plugin-sharp": "^5.16.0",
    "gatsby-plugin-typography": "^5.16.0",
    "gatsby-remark-autolink-headers": "^6.16.0",
    "gatsby-remark-external-links": "^0.0.4",
    "gatsby-source-filesystem": "^5.16.0",
    "gatsby-transformer-remark": "^6.16.0",
    "gatsby-transformer-sharp": "^5.16.0",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "normalize.css": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet": "^6.1.0",
    "react-i18next": "^17.0.2",
    "react-typography": "^0.16.23",
    "typography": "^0.16.24"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@types/reach__router": "^1.3.15",
    "@types/react": "^18.3.13",
    "@types/react-dom": "^18.3.0",
    "@types/react-helmet": "^6.1.11",
    "@types/typography": "^0.16.9",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "gatsby-plugin-netlify": "^5.1.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "sass": "^1.99.0",
    "stylelint": "^17.6.0",
    "stylelint-config-recommended-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.58.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "core-js",
      "core-js-pure",
      "es5-ext",
      "gatsby",
      "gatsby-cli",
      "lmdb",
      "msgpackr-extract",
      "sharp",
      "unrs-resolver"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint": "10",
        "react": "18",
        "react-dom": "18",
        "gatsby": "5"
      }
    },
    "overrides": {
      "@typescript-eslint/eslint-plugin": "^8.58.0",
      "@typescript-eslint/parser": "^8.58.0",
      "@typescript-eslint/typescript-estree": "^8.58.0"
    }
  }
}
